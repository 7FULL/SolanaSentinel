# SolanaSentinel Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True
ENVIRONMENT=development

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
SOLANA_COMMITMENT=confirmed

# For better performance, consider using a paid RPC provider:
# SOLANA_RPC_URL=https://your-rpc-provider.com/api-key
# SOLANA_WS_URL=wss://your-rpc-provider.com/api-key

# Security
ENCRYPTION_PASSWORD=change_this_to_a_strong_password
MAX_TRANSACTION_AMOUNT=10.0
REQUIRE_CONFIRMATION=True

# Logging
LOG_LEVEL=INFO

# Copy Trading (optional defaults)
# COPY_TRADING_ENABLED=False
# COPY_TRADING_MODE=notification

# Sniper Bot (optional defaults)
# SNIPER_ENABLED=False
# SNIPER_MODE=simulation
# SNIPER_MIN_LIQUIDITY=1000

# Anti-Scam (optional defaults)
# ANTI_SCAM_ENABLED=True
# ANTI_SCAM_STRICT_MODE=False
# AI_ANALYSIS_ENABLED=False

# Notifications — Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# Notifications — Discord
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# Flask port (default 5005)
FLASK_PORT=5005
